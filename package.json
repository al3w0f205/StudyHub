    "db:seed": "tsx scripts/seed.ts",
    "db:admin": "tsx scripts/create-admin.ts",
    "prisma:generate": "npx prisma generate",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "dev:preview": "tsx scripts/dev-preview.ts",
    "test": "jest",
    "prepare": "husky"
  },
  "dependencies": {
