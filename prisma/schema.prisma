// StudyHub — Prisma Schema
// PostgreSQL + Auth.js v5 + Application Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════
// Auth.js Required Models
// ═══════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════
// Application Models
// ═══════════════════════════════════════════════════

enum Role {
  USER
  ADMIN
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  password            String?              // Hashed — only for ADMIN credentials login
  role                Role                 @default(USER)
  subscriptionExpiry  DateTime?
  isSuspended         Boolean              @default(false)
  suspendedReason     String?
  allowedCareers      String?              // Comma-separated career slugs. null or "" = NO access. Admin must assign.

  accounts            Account[]
  sessions            Session[]
  paymentRequests     PaymentRequest[]
  questionSuggestions QuestionSuggestion[]
  quizProgress        QuizProgress[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Career {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?    // emoji or icon identifier
  categories  Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Category {
  id           String         @id @default(cuid())
  name         String
  slug         String
  description  String?
  careerId     String
  career       Career         @relation(fields: [careerId], references: [id], onDelete: Cascade)
  questions    Question[]
  quizProgress QuizProgress[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([careerId, slug])
}

model Question {
  id           String   @id @default(cuid())
  text         String   @db.Text
  options      Json     // ["opción A", "opción B", "opción C", "opción D"]
  correctIndex Int      // 0-based index of the correct option
  hint         String?  @db.Text
  explanation  String?  @db.Text
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PaymentRequest {
  id               String               @id @default(cuid())
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  receiptUrl       String               // S3/MinIO URL of the payment receipt photo
  status           PaymentRequestStatus @default(PENDING)
  adminNotes       String?
  userComment      String?              @db.Text // User's comment/message with payment
  requestedCareers String?              // Comma-separated career slugs the user wants access to
  reviewedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model QuestionSuggestion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text        String   @db.Text
  options     Json
  correctIndex Int?    // The index of the correct option
  hint        String?  @db.Text
  explanation String?  @db.Text
  categoryId  String?
  isReviewed  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model QuizProgress {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  score      Int      // Best score percentage
  attempts   Int      @default(1)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId])
}
